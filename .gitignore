# ===========================
# NexusFlow AI — Root .gitignore
# ===========================

# Dependencies
node_modules/
.npm
.yarn

# Build outputs
dist/
build/
.next/
out/

# Environment files — NEVER commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Keep examples
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage & test artifacts
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/

# Prisma
backend/prisma/dev.db
backend/prisma/dev.db-journal

# Uploads directory (runtime files)
backend/uploads/*
!backend/uploads/.gitkeep

# TypeScript build info
*.tsbuildinfo
tsconfig.tsbuildinfo

# Vite
.vite/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor & IDE
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak
*.tmp
*.temp
*~
.project
.classpath

# Docker volumes
docker-data/
postgres-data/

# PM2
.pm2/

# Wrangler (if used)
.wrangler/

# Vercel
.vercel/

# Railway
.railway/

# Turborepo
.turbo/

# Miscellaneous
*.zip
*.tar.gz
*.tgz
*.rar
.cache/
tmp/
temp/
